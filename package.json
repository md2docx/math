{
  "name": "md2docx-plugin-template",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean",
    "dev": "turbo dev",
    "format": "biome check . --write",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "preinstall": "node scripts/update-pm.js"
  },
  "pre-commit": [
    "format"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@promptshield/cli": "^1.0.0",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.6.0",
    "turbo": "^2.9.9"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@biomejs/biome": "^2.5.0",
    "pre-commit": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "cross-spawn@<6.0.6": ">=6.0.6"
    }
  }
}
